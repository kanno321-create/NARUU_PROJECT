  "informational_check_definitions": {
    "CHK_PBL_ON_OFF": {
      "id": "CHK_PBL_ON_OFF",
      "class": "INFORMATIONAL",
      "description": "PBL 스위치 수량 확인 (= 마그네트 수량 × 2)",
      "trigger": "PBL 스위치가 BOM에 존재하는 경우",
      "formula": "PBL_qty = Magnet_qty × 2",
      "validation_logic": {
        "step_1": "BOM에서 마그네트 수량 확인",
        "step_2": "BOM에서 PBL 수량 확인",
        "step_3": "PBL 수량 = 마그네트 수량 × 2 확인"
      },
      "failure_action": "경고",
      "warning_message": "PBL 스위치 수량이 마그네트 수량 × 2와 일치하지 않습니다. 확인하세요.",
      "reference": "3_accessories.json → bundle_rules → BND_PBL_ON_OFF"
    },

    "CHK_PVC_DUCT_EFFECT": {
      "id": "CHK_PVC_DUCT_EFFECT",
      "class": "INFORMATIONAL",
      "description": "PVC 덕트 포함 시 유효폭 감소 확인 (-100mm)",
      "trigger": "PVC 덕트가 BOM에 존재하는 경우",
      "width_reduction": 100,
      "calculation": "좌우 여유 각 30mm + 덕트 폭 40mm = -100mm",
      "validation_logic": {
        "step_1": "BOM에서 PVC 덕트 존재 확인",
        "step_2": "외함 유효폭 = 외함폭 - 100mm 적용 확인"
      },
      "failure_action": "경고",
      "warning_message": "PVC 덕트가 포함되어 있습니다. 유효폭 -100mm가 적용되었는지 확인하세요.",
      "reference": "3_accessories.json → bundle_rules → BND_PVC_DUCT_EFFECT"
    },

    "CHK_FIT_SCORE": {
      "id": "CHK_FIT_SCORE",
      "class": "QUALITY_GATE",
      "description": "외함 적합도 확인 (≥ 0.90)",
      "threshold": 0.90,
      "formula": "fit_score = 실제_사용_공간 / 외함_내부_공간",
      "validation_logic": {
        "step_1": "차단기 + 부속자재 총 체적 계산",
        "step_2": "외함 내부 체적 계산",
        "step_3": "fit_score = 총_체적 / 내부_체적 계산",
        "step_4": "fit_score ≥ 0.90 확인"
      },
      "failure_action": "경고",
      "warning_message": "외함 적합도가 0.90 미만입니다. 외함 크기를 재검토하세요.",
      "reference": "2_enclosures.json → validation_rules → fit_score"
    },

    "CHK_IP_RATING": {
      "id": "CHK_IP_RATING",
      "class": "QUALITY_GATE",
      "description": "IP 등급 확인",
      "indoor_minimum": "IP44",
      "outdoor_minimum": "IP54",
      "validation_logic": {
        "step_1": "설치 장소 확인 (옥내/옥외)",
        "step_2": "외함 IP 등급 확인",
        "step_3": "옥내: IP44 이상, 옥외: IP54 이상 확인"
      },
      "failure_action": "경고",
      "warning_message": "IP 등급이 최소 요구사항을 충족하지 않습니다.",
      "reference": "2_enclosures.json → validation_rules → ip_rating"
    },

    "CHK_DOOR_CLEARANCE": {
      "id": "CHK_DOOR_CLEARANCE",
      "class": "QUALITY_GATE",
      "description": "도어 여유 확인 (≥ 30mm)",
      "threshold": 30,
      "unit": "mm",
      "validation_logic": {
        "step_1": "외함 깊이 확인",
        "step_2": "차단기 최대 깊이 확인",
        "step_3": "도어 여유 = 외함깊이 - 차단기깊이 - 배선여유 계산",
        "step_4": "도어 여유 ≥ 30mm 확인"
      },
      "failure_action": "경고",
      "warning_message": "도어 여유가 30mm 미만입니다. 외함 깊이를 늘리세요.",
      "reference": "2_enclosures.json → validation_rules → door_clearance"
    }
  },

  "quality_gates": {
    "description": "품질 게이트 기준 (FIX-4 파이프라인)",
    "stages": {
      "stage_1_enclosure": {
        "name": "Enclosure (외함 계산)",
        "gates": [
          {
            "metric": "fit_score",
            "threshold": "≥ 0.90",
            "enforcement": "FAIL_FAST"
          },
          {
            "metric": "ip_rating",
            "threshold": "≥ IP44 (옥내) 또는 ≥ IP54 (옥외)",
            "enforcement": "FAIL_FAST"
          },
          {
            "metric": "door_clearance",
            "threshold": "≥ 30mm",
            "enforcement": "FAIL_FAST"
          }
        ]
      },
      "stage_2_breaker": {
        "name": "Breaker (차단기 배치)",
        "gates": [
          {
            "metric": "phase_balance",
            "threshold": "≤ 4%",
            "enforcement": "FAIL_FAST"
          },
          {
            "metric": "clearance_violations",
            "threshold": "= 0",
            "enforcement": "FAIL_FAST"
          },
          {
            "metric": "thermal_violations",
            "threshold": "= 0",
            "enforcement": "FAIL_FAST"
          }
        ]
      },
      "stage_3_format": {
        "name": "Format (문서 포맷)",
        "gates": [
          {
            "metric": "formula_preservation",
            "threshold": "= 100%",
            "enforcement": "FAIL_FAST"
          },
          {
            "metric": "named_range_damage",
            "threshold": "= 0",
            "enforcement": "FAIL_FAST"
          }
        ]
      },
      "stage_4_cover": {
        "name": "Cover (표지 생성)",
        "gates": [
          {
            "metric": "cover_compliance",
            "threshold": "= 100%",
            "enforcement": "FAIL_FAST"
          }
        ]
      },
      "stage_5_doc_lint": {
        "name": "Doc Lint (최종 검증)",
        "gates": [
          {
