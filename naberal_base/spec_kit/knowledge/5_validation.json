          "rule": "같은 프레임끼리 행(Row) 단위 Pairing"
        }
      },
      "validation_logic": {
        "step_1": "모든 차단기 쌍에 대해 거리 계산",
        "step_2": "좌우 간격 ≥ 10mm 확인",
        "step_3": "상하 간격 ≥ 10mm 확인",
        "step_4": "마주보기 배치 시 프레임 일치 확인",
        "step_5": "위반 건수 = 0 확인"
      },
      "failure_action": "견적 차단",
      "error_message": "차단기 간 간섭이 발생했습니다. 배치를 재조정하세요.",
      "reference": "1_breakers.json → layout_rules → facing_arrangement"
    },

    "CHK_THERMAL_VIOLATIONS": {
      "id": "CHK_THERMAL_VIOLATIONS",
      "class": "MANDATORY",
      "priority": 6,
      "description": "열 밀도 위반 확인 (= 0)",
      "trigger": "차단기 배치 시",
      "threshold": 0,
      "thermal_limits": {
        "max_current_density": {
          "value": 0.8,
          "unit": "A/mm²",
          "description": "최대 전류 밀도"
        },
        "temperature_rise": {
          "max_K": 70,
          "description": "최대 온도 상승 (IEC 61439-1:2020)"
        }
      },
      "validation_logic": {
        "step_1": "각 차단기별 발열량 계산",
        "step_2": "외함 내부 총 발열량 계산",
        "step_3": "외함 체적당 발열량 확인",
        "step_4": "열 밀도 한계값 초과 확인",
        "step_5": "위반 건수 = 0 확인"
      },
      "failure_action": "견적 차단",
      "error_message": "열 밀도가 안전 한계를 초과했습니다. 외함 크기를 늘리거나 차단기 수량을 줄이세요.",
      "reference": "IEC 61439-1:2020 온도 상승 설계값"
    },

    "CHK_FORMULA_PRESERVATION": {
      "id": "CHK_FORMULA_PRESERVATION",
      "class": "MANDATORY",
      "priority": 7,
      "description": "Excel 수식 보존 확인 (= 100%)",
      "trigger": "Excel 문서 생성 시",
      "threshold": 100,
      "unit": "%",
      "critical_formulas": [
        {
          "cell": "G[소계행]",
          "formula": "=SUM(G3:G[조립비행])",
          "description": "소계 행 합계 수식"
        },
        {
          "cell": "G[합계행]",
          "formula": "=소계G×합계E",
          "description": "합계 행 계산 수식"
        },
        {
          "cell": "H17 (표지)",
          "formula": "=+견적서!G[소계행]",
          "description": "표지 분전반 가격 링크"
        },
        {
          "cell": "I17 (표지)",
          "formula": "=H17*G17",
          "description": "표지 금액 계산"
        },
        {
          "cell": "I18 (표지)",
          "formula": "=SUM(I17:I[마지막분전반])",
          "description": "표지 소계"
        },
        {
          "cell": "I19 (표지)",
          "formula": "=I18*1.1",
          "description": "부가세 포함 금액"
        }
      ],
      "validation_logic": {
        "step_1": "생성된 Excel 파일 열기",
        "step_2": "각 중요 셀의 수식 존재 여부 확인",
        "step_3": "수식 형식이 올바른지 확인",
        "step_4": "네임드 범위 손상 확인",
        "step_5": "수식 보존율 = (보존된_수식 / 총_수식) × 100 계산",
        "step_6": "수식 보존율 = 100% 확인"
      },
      "failure_action": "견적 차단",
      "error_message": "Excel 수식이 손상되었습니다. 수식 보존율 100%를 유지해야 합니다.",
      "reference": "견적서장성법V1.0.txt (소계/합계 수식)"
    }
  },

