  "check_definitions": {
    "CHK_BUNDLE_MAGNET": {
      "id": "CHK_BUNDLE_MAGNET",
      "class": "MANDATORY",
      "priority": 1,
      "description": "마그네트 존재 시 동반자재 포함 확인",
      "trigger": "마그네트 컨택터가 BOM에 존재하는 경우",
      "required_items": [
        {
          "item_id": "FUSEHOLDER",
          "qty_per_magnet": 1,
          "price": 4000
        },
        {
          "item_id": "TERMINAL_BLOCK_600V",
          "qty_per_magnet": 3,
          "price": 4000,
          "critical_note": "CRITICAL: 3개임 (sub_material_bundles.json에 1개로 잘못 기재)"
        },
        {
          "item_id": "PVC_DUCT_40",
          "qty_per_magnet": 2,
          "price": 3000,
          "critical_note": "CRITICAL: 상단 1개 + 하단 1개 = 2개"
        },
        {
          "item_id": "CABLE_WIRE",
          "qty_per_magnet": 2,
          "price": 25000,
          "critical_note": "CRITICAL: 2개임 (sub_material_bundles.json에 1개로 잘못 기재)"
        }
      ],
      "labor_cost_required": 20000,
      "validation_logic": {
        "step_1": "BOM에서 마그네트 컨택터 수량 확인",
        "step_2": "각 동반자재가 BOM에 포함되어 있는지 확인",
        "step_3": "각 동반자재의 수량이 정확한지 확인 (마그네트 수량 × 필요 수량)",
        "step_4": "인건비가 포함되어 있는지 확인 (마그네트 수량 × 20,000원)"
      },
      "failure_action": "견적 차단",
      "error_message": "마그네트 컨택터가 포함되어 있으나 필수 동반자재가 누락되었습니다. FUSEHOLDER, TERMINAL_BLOCK_600V (×3), PVC_DUCT_40 (×2), CABLE_WIRE (×2), 인건비를 추가하세요.",
      "reference": "3_accessories.json → bundle_rules → BND_MAGNET_BASE"
    },

    "CHK_BUNDLE_TIMER": {
      "id": "CHK_BUNDLE_TIMER",
      "class": "MANDATORY",
      "priority": 2,
      "description": "타이머 존재 시 동반자재 포함 확인",
      "trigger": "타이머가 BOM에 존재하는 경우",
      "required_items": [
        {
          "item_id": "CABLE_WIRE",
          "qty_per_timer": 1,
          "price": 25000
        }
      ],
      "labor_cost_required": 12000,
      "validation_logic": {
        "step_1": "BOM에서 타이머 수량 확인",
        "step_2": "CABLE_WIRE가 BOM에 포함되어 있는지 확인",
        "step_3": "CABLE_WIRE 수량이 정확한지 확인 (타이머 수량 × 1)",
        "step_4": "인건비가 포함되어 있는지 확인 (타이머 수량 × 12,000원)"
      },
      "failure_action": "견적 차단",
      "error_message": "타이머가 포함되어 있으나 필수 동반자재가 누락되었습니다. CABLE_WIRE, 인건비를 추가하세요.",
      "reference": "3_accessories.json → bundle_rules → BND_TIMER_EFFECT"
    },

    "CHK_ENCLOSURE_H_FORMULA": {
      "id": "CHK_ENCLOSURE_H_FORMULA",
      "class": "MANDATORY",
      "priority": 3,
      "description": "외함 높이 공식 적용 확인",
      "trigger": "외함 크기 계산 시",
      "formula": "H = A + B + C + D + E",
      "components": {
        "A": "상단 여유 (메인 차단기 프레임별)",
        "B": "메인-분기 간격 (30mm)",
        "C": "분기차단기 총 높이",
        "D": "하단 여유 (메인 암페어별)",
        "E": "부속자재 여유 (PVC 덕트 40mm, 마그네트 높이 등)"
      },
      "validation_logic": {
        "step_1": "각 컴포넌트(A, B, C, D, E) 값 계산",
        "step_2": "총 높이 H = A + B + C + D + E 계산",
        "step_3": "계산된 H값이 외함 높이로 사용되었는지 확인",
        "step_4": "2칸 취부 시 보정 적용 확인 (H = Panel1_H + Panel2_H + 격벽(50mm) + 여유)"
      },
      "special_cases": {
        "dual_panel": {
          "description": "1면 외함에 분전반 2개",
          "formula": "H = Panel1_H + Panel2_H + 중간격벽(50mm) + 상여유 + 하여유"
        },
        "with_accessories": {
          "description": "부속자재 포함 시",
          "formula": "H = 기본H + PVC_덕트(2×40mm) + 마그네트_높이"
        }
      },
      "failure_action": "견적 차단",
      "error_message": "외함 높이 공식이 올바르게 적용되지 않았습니다. H = A + B + C + D + E 공식을 확인하세요.",
      "reference": "2_enclosures.json → sizing_rules → height_calculation"
    },

    "CHK_PHASE_BALANCE": {
      "id": "CHK_PHASE_BALANCE",
      "class": "MANDATORY",
      "priority": 4,
      "description": "상평형 확인 (≤ 4%)",
      "trigger": "3상 분기차단기 배치 시",
      "threshold": 4.0,
      "unit": "%",
      "formula": "상평형 = max(|R상_전류 - 평균전류|, |S상_전류 - 평균전류|, |T상_전류 - 평균전류|) / 평균전류 × 100",
      "validation_logic": {
        "step_1": "각 상(R, S, T)별 총 전류 계산",
        "step_2": "평균 전류 = (R + S + T) / 3 계산",
        "step_3": "각 상별 편차 = |상_전류 - 평균_전류| 계산",
        "step_4": "최대 편차 / 평균_전류 × 100 계산",
        "step_5": "상평형 ≤ 4% 확인"
      },
      "examples": [
        {
          "R_current": 100,
          "S_current": 95,
          "T_current": 105,
          "average": 100,
          "max_deviation": 5,
          "phase_balance": 5.0,
          "result": "FAIL (5% > 4%)"
        },
        {
          "R_current": 100,
          "S_current": 98,
          "T_current": 102,
          "average": 100,
          "max_deviation": 2,
          "phase_balance": 2.0,
          "result": "PASS (2% ≤ 4%)"
        }
      ],
      "failure_action": "견적 차단",
      "error_message": "상평형이 4%를 초과했습니다. 분기차단기 배치를 재조정하세요.",
      "reference": "1_breakers.json → layout_rules → branch_bus_connection"
    },

    "CHK_CLEARANCE_VIOLATIONS": {
